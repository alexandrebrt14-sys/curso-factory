/* step id → icon key mapping */
const STEP_ICONS: Record<string, keyof typeof icons> = {
{% for step in steps %}
  "{{ step.id }}": "{{ step.icon_key }}",
{% endfor %}
};

/* ───────── DATA ───────── */
const STEPS: Step[] = [
{% for step in steps %}
  {
    id: "{{ step.id }}",
    title: "{{ step.title | js_escape }}",
    duration: "{{ step.duration }}",
    icon: "{{ '%02d' % loop.index }}",
    description: "{{ step.description | js_escape }}",
    content: [
{% for section in step.content %}
{% if section.type == "code" %}
      { type: "code", value: "{{ section.value | js_escape }}", language: "{{ section.language | default('text') }}" },
{% else %}
      { type: "{{ section.type }}", value: "{{ section.value | js_escape }}" },
{% endif %}
{% endfor %}
    ],
  },
{% endfor %}
];

/* ───────── HELPER: copy to clipboard ───────── */
function copyToClipboard(text: string) {
  navigator.clipboard.writeText(text);
}

/* ───────── COMPONENT: CodeBlock ───────── */
function CodeBlock({ code, language }: { code: string; language?: string }) {
  const [copied, setCopied] = useState(false);
  const cleanCode = code.replace(/^#.*\n?/gm, "").trim();

  const handleCopy = () => {
    copyToClipboard(cleanCode || code);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  return (
    <div className="relative group rounded-[var(--radius)] overflow-hidden border border-[var(--border)] bg-[#1e1e2e] my-4">
      <div className="flex items-center justify-between px-4 py-2 bg-[#181825] border-b border-[#313244]">
        <span className="text-xs text-[#a6adc8] font-mono">{language || "terminal"}</span>
        <button
          onClick={handleCopy}
          className="text-xs text-[#a6adc8] hover:text-white transition-colors flex items-center gap-1.5 px-2 py-1 rounded hover:bg-[#313244]"
        >
          {copied ? (
            <>{icons.clipboardCheck} Copiado</>
          ) : (
            <>{icons.clipboard} Copiar</>
          )}
        </button>
      </div>
      <pre className="p-4 overflow-x-auto text-sm leading-relaxed">
        <code className="text-[#cdd6f4] font-mono whitespace-pre-wrap break-words">
          {code.split("\n").map((line, i) => (
            <span key={i} className="block">
              {line.startsWith("#") ? (
                <span className="text-[#6c7086]">{line}</span>
              ) : line.startsWith(">") ? (
                <span className="text-[#a6e3a1]">{line}</span>
              ) : line.startsWith("//") ? (
                <span className="text-[#6c7086]">{line}</span>
              ) : line.match(/^[A-Z_]+=/) ? (
                <span className="text-[#f9e2af]">{line}</span>
              ) : line.match(/^"@/) ? (
                <span className="text-[#cba6f7]">{line}</span>
              ) : (
                <span>{line}</span>
              )}
            </span>
          ))}
        </code>
      </pre>
    </div>
  );
}

/* ───────── COMPONENT: StepCard ───────── */
function StepCard({
  step,
  index,
  isOpen,
  isCompleted,
  onToggle,
  onComplete,
}: {
  step: Step;
  index: number;
  isOpen: boolean;
  isCompleted: boolean;
  onToggle: () => void;
  onComplete: () => void;
}) {
  return (
    <div
      id={step.id}
      className={`rounded-[var(--radius-lg)] border transition-all duration-300 ${
        isOpen
          ? "border-[var(--accent)] shadow-lg"
          : isCompleted
          ? "border-[var(--success)] bg-[var(--success-light)]/30"
          : "border-[var(--border)] hover:border-[var(--accent)]/50"
      }`}
    >
      {/* Header */}
      <button
        onClick={onToggle}
        className="w-full flex items-center gap-4 p-5 sm:p-6 text-left group"
      >
        {/* Step icon circle (Lucide) */}
        <div
          className={`flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center transition-all duration-200 ${
            isCompleted
              ? "bg-[var(--success)] text-white shadow-[0_2px_8px_rgba(46,132,74,0.3)]"
              : isOpen
              ? "bg-[var(--accent)] text-white shadow-[0_2px_8px_rgba(1,118,211,0.3)]"
              : "bg-[var(--bg-muted)] text-[var(--text-muted)] group-hover:bg-[var(--accent-lighter)] group-hover:text-[var(--accent)]"
          }`}
        >
          {isCompleted ? icons.checkLg : (icons[STEP_ICONS[step.id]] || <span className="text-sm font-bold">{String(index + 1).padStart(2, "0")}</span>)}
        </div>

        {/* Title & meta */}
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2 mb-1 flex-wrap">
            <h3 className={`font-bold text-lg ${isCompleted ? "text-[var(--success)]" : "text-[var(--text)]"}`}>
              {step.title}
            </h3>
            <span className="text-xs font-medium text-[var(--text-light)] bg-[var(--bg-muted)] px-2 py-0.5 rounded-full">
              {step.duration}
            </span>
          </div>
          <p className="text-sm text-[var(--text-muted)] line-clamp-1">{step.description}</p>
        </div>

        {/* Chevron */}
        <span className={`flex-shrink-0 transition-transform duration-300 ${isOpen ? "rotate-180" : ""}`}>
          {icons.chevronDown}
        </span>
      </button>

      {/* Content */}
      {isOpen && (
        <div className="px-5 sm:px-6 pb-6 border-t border-[var(--border-light)]">
          <div className="pt-5 pl-0 sm:pl-16 space-y-4">
            {step.content.map((section, i) => {
              switch (section.type) {
                case "text":
                  return (
                    <div key={i} className="text-[var(--text)] text-[15px] leading-relaxed whitespace-pre-line">
                      {section.value.split("\n").map((line, j) => (
                        <p key={j} className={line.match(/^\d+\./) ? "pl-4 mb-1" : line.startsWith("--") ? "pl-4 mb-1" : "mb-3"}>
                          {line.startsWith("--") ? line.replace("--", "\u2022") : line}
                        </p>
                      ))}
                    </div>
                  );
                case "code":
                  return <CodeBlock key={i} code={section.value} language={section.language} />;
                case "warning":
                  return (
                    <div key={i} className="flex gap-3 p-4 rounded-[var(--radius)] bg-[#fff8e1] border border-[#ffe082]">
                      <span className="flex-shrink-0 mt-0.5">{icons.alertTriangle}</span>
                      <p className="text-sm text-[#5d4037] leading-relaxed">{section.value}</p>
                    </div>
                  );
                case "tip":
                  return (
                    <div key={i} className="flex gap-3 p-4 rounded-[var(--radius)] bg-[var(--accent-lighter)] border border-[var(--accent)]/20">
                      <span className="flex-shrink-0 mt-0.5">{icons.lightbulb}</span>
                      <p className="text-sm text-[var(--accent-dark)] leading-relaxed">{section.value}</p>
                    </div>
                  );
                case "checkpoint":
                  return (
                    <div key={i} className="flex gap-3 p-4 rounded-[var(--radius)] bg-[var(--success-light)] border border-[var(--success)]/20">
                      <span className="flex-shrink-0 mt-0.5">{icons.circleCheck}</span>
                      <div>
                        <span className="text-xs font-bold text-[var(--success)] uppercase tracking-wider block mb-1">Checkpoint</span>
                        <p className="text-sm text-[var(--success)] leading-relaxed">{section.value}</p>
                      </div>
                    </div>
                  );
                default:
                  return null;
              }
            })}

            {/* Complete step button */}
            <div className="pt-4 flex items-center gap-3">
              <button
                onClick={onComplete}
                className={`inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius)] font-semibold text-sm transition-all ${
                  isCompleted
                    ? "bg-[var(--success-light)] text-[var(--success)] border border-[var(--success)]/30"
                    : "bg-[var(--accent)] text-white hover:bg-[var(--accent-dark)]"
                }`}
                style={isCompleted ? {} : { color: "#fff" }}
              >
                {isCompleted ? (
                  <>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Concluido
                  </>
                ) : (
                  <>
                    Marcar como concluido
                    {icons.chevronRight}
                  </>
                )}
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

/* ───────── FAQ DATA ───────── */
const FAQ_ITEMS = [
{% for item in faq %}
  {
    q: "{{ item.pergunta | js_escape }}",
    a: "{{ item.resposta | js_escape }}",
  },
{% endfor %}
];

/* ───────── MAIN PAGE ───────── */
export default function {{ component_name }}() {
  const [openStep, setOpenStep] = useState<string | null>("{{ steps[0].id }}");
  const [completed, setCompleted] = useState<Set<string>>(new Set());

  // Load progress from localStorage
  useEffect(() => {
    const saved = localStorage.getItem("{{ local_storage_key | js_escape }}");
    if (saved) {
      try {
        setCompleted(new Set(JSON.parse(saved)));
      } catch { /* ignore */ }
    }
  }, []);

  // Save progress
  useEffect(() => {
    if (completed.size > 0) {
      localStorage.setItem("{{ local_storage_key | js_escape }}", JSON.stringify([...completed]));
    }
  }, [completed]);

  const toggleStep = (id: string) => {
    setOpenStep(openStep === id ? null : id);
  };

  const completeStep = (id: string) => {
    const next = new Set(completed);
    if (next.has(id)) {
      next.delete(id);
    } else {
      next.add(id);
      // Open next step
      const currentIndex = STEPS.findIndex((s) => s.id === id);
      if (currentIndex < STEPS.length - 1) {
        setOpenStep(STEPS[currentIndex + 1].id);
      }
    }
    setCompleted(next);
  };

  const progress = Math.round((completed.size / STEPS.length) * 100);

  const resetProgress = () => {
    setCompleted(new Set());
    setOpenStep("{{ steps[0].id }}");
    localStorage.removeItem("{{ local_storage_key | js_escape }}");
  };

  return (
    <>
      <Topbar />
      <Breadcrumbs
        items={[
          { label: "Inicio", href: "/" },
          { label: "Educacao", href: "/educacao" },
          { label: "{{ breadcrumb_label | js_escape }}" },
        ]}
      />

      <main id="main-content">
        {/* Hero */}
        <section className="py-16 sm:py-20 px-6" style={% raw %}{{ background: "linear-gradient(135deg, {{ hero_gradient_from }} 0%, {{ hero_gradient_to }} 100%)" }}{% endraw %}>
          <div className="max-w-[var(--max)] mx-auto">
            <div className="max-w-3xl">
              <span className="sf-label mb-3 block text-white/80">{{ descricao_curta | js_escape }}</span>
              <h1 className="text-[clamp(28px,4vw,44px)] font-extrabold text-white leading-[1.1] mb-5">
                {{ titulo | js_escape }}
              </h1>
              <p className="text-lg text-white/80 leading-relaxed mb-8 max-w-2xl">
                {{ descricao | js_escape }}
              </p>

              {/* Stats row */}
              <div className="flex flex-wrap gap-6 text-sm">
                <div className="flex items-center gap-2 text-white/80">
                  {icons.clock}
                  <span>Tempo estimado: ~{{ duracao_display }}</span>
                </div>
                <div className="flex items-center gap-2 text-white/80">
                  {icons.bookOpen}
                  <span>{STEPS.length} modulos</span>
                </div>
                <div className="flex items-center gap-2 text-white/80">
                  {icons.graduationCap}
                  <span>Nivel: {{ nivel_display | js_escape }}</span>
                </div>
                <div className="flex items-center gap-2 text-white/80">
                  {icons.layers}
                  <span>{{ tags | join(', ') }}</span>
                </div>
              </div>
            </div>
          </div>
        </section>

        {/* Progress bar */}
        <div className="sticky top-[57px] z-[5] bg-white/95 backdrop-blur-sm border-b border-[var(--border)]">
          <div className="max-w-[var(--max)] mx-auto px-6 py-3">
            <div className="flex items-center justify-between gap-4">
              <div className="flex items-center gap-3 flex-1">
                <span className="text-sm font-semibold text-[var(--text)] whitespace-nowrap">
                  {completed.size}/{STEPS.length} concluidos
                </span>
                <div className="flex-1 h-2 bg-[var(--bg-muted)] rounded-full overflow-hidden">
                  <div
                    className="h-full rounded-full transition-all duration-500 ease-out"
                    style={% raw %}{{
                      width: `${progress}%`,
                      background: progress === 100
                        ? "var(--success)"
                        : "var(--accent)",
                    }}{% endraw %}
                  />
                </div>
                <span className="text-sm font-bold text-[var(--accent)] whitespace-nowrap">
                  {progress}%
                </span>
              </div>
              {completed.size > 0 && (
                <button
                  onClick={resetProgress}
                  className="text-xs text-[var(--text-light)] hover:text-[var(--text)] transition-colors"
                >
                  Resetar
                </button>
              )}
            </div>
          </div>
        </div>

        {/* Course sidebar + content */}
        <section className="py-12 px-6">
          <div className="max-w-[var(--max)] mx-auto">
            <div className="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8">
              {/* Sidebar - module index */}
              <aside className="hidden lg:block">
                <div className="sticky top-[110px]">
                  <h4 className="font-bold text-[var(--text)] text-sm mb-4 uppercase tracking-wider">
                    Modulos
                  </h4>
                  <nav className="space-y-1">
                    {STEPS.map((step, i) => (
                      <button
                        key={step.id}
                        onClick={() => {
                          setOpenStep(step.id);
                          document.getElementById(step.id)?.scrollIntoView({ behavior: "smooth", block: "center" });
                        }}
                        className={`w-full text-left flex items-center gap-3 px-3 py-2.5 rounded-[var(--radius)] text-sm transition-colors ${
                          openStep === step.id
                            ? "bg-[var(--accent-lighter)] text-[var(--accent)] font-semibold"
                            : completed.has(step.id)
                            ? "text-[var(--success)] hover:bg-[var(--success-light)]"
                            : "text-[var(--text-muted)] hover:bg-[var(--bg-muted)] hover:text-[var(--text)]"
                        }`}
                      >
                        <span className={`flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center transition-all ${
                          completed.has(step.id)
                            ? "bg-[var(--success)] text-white"
                            : openStep === step.id
                            ? "bg-[var(--accent)] text-white"
                            : "bg-[var(--bg-muted)] text-[var(--text-muted)]"
                        }`}>
                          {completed.has(step.id) ? (
                            icons.check
                          ) : (
                            <span className="[&>svg]:w-3.5 [&>svg]:h-3.5">{icons[STEP_ICONS[step.id]] || String(i + 1).padStart(2, "0")}</span>
                          )}
                        </span>
                        <span className="truncate">{step.title}</span>
                      </button>
                    ))}
                  </nav>

                  {/* Prerequisites card */}
                  <div className="mt-8 p-4 rounded-[var(--radius)] bg-[var(--bg-muted)] border border-[var(--border-light)]">
                    <h5 className="font-bold text-sm text-[var(--text)] mb-2">Pre-requisitos</h5>
                    <ul className="text-xs text-[var(--text-muted)] space-y-2">
{% for prereq in prerequisitos_display %}
                      <li className="flex items-start gap-2">
                        <span className="mt-0.5 flex-shrink-0">{icons.targetSm}</span>
                        {{ prereq | js_escape }}
                      </li>
{% endfor %}
                    </ul>
                  </div>
                </div>
              </aside>

              {/* Steps list */}
              <div className="space-y-4">
                {/* Intro card */}
                <div className="p-6 rounded-[var(--radius-lg)] bg-[var(--card-dark)] text-white mb-6">
                  <h2 className="text-xl font-bold mb-3">O que voce vai aprender</h2>
                  <p className="text-sm text-[#a6adc8] leading-relaxed mb-4">
                    {{ descricao | js_escape }}
                  </p>
                  <div className="grid grid-cols-1 sm:grid-cols-3 gap-3">
{% for tag in tags[:3] %}
                    <div className="flex items-center gap-3 text-sm text-[#cdd6f4] bg-white/5 rounded-lg px-3 py-2.5">
                      <span className="text-[#a6e3a1]">{icons.checkCircle}</span>
                      {{ tag | js_escape }}
                    </div>
{% endfor %}
                  </div>
                </div>

                {/* Steps */}
                {STEPS.map((step, i) => (
                  <StepCard
                    key={step.id}
                    step={step}
                    index={i}
                    isOpen={openStep === step.id}
                    isCompleted={completed.has(step.id)}
                    onToggle={() => toggleStep(step.id)}
                    onComplete={() => completeStep(step.id)}
                  />
                ))}

                {/* Completion card */}
                {completed.size === STEPS.length && (
                  <div className="p-8 rounded-[var(--radius-lg)] bg-gradient-to-br from-[var(--success-light)] to-white border-2 border-[var(--success)] text-center">
                    <div className="w-16 h-16 mx-auto mb-4 rounded-2xl bg-[var(--success)] flex items-center justify-center shadow-[0_4px_16px_rgba(46,132,74,0.3)]">
                      {icons.checkCircleLg}
                    </div>
                    <h2 className="text-2xl font-bold text-[var(--success)] mb-2">Curso concluido com sucesso!</h2>
                    <p className="text-[var(--text-muted)] mb-6 max-w-lg mx-auto">
                      Parabens! Voce completou todos os {STEPS.length} modulos do curso {{ titulo | js_escape }}.
                    </p>
                    <div className="flex flex-wrap items-center justify-center gap-3">
                      <a href="/educacao" className="sf-btn-primary" style={% raw %}{{ color: "#fff" }}{% endraw %}>
                        Explorar outros cursos
                      </a>
                      <a href="/conteudos" className="sf-btn-outline">
                        Ler artigos tecnicos
                      </a>
                    </div>
                  </div>
                )}

                {/* FAQ section */}
                <div className="mt-12 pt-12 border-t border-[var(--border)]">
                  <div className="flex items-center gap-3 mb-6">
                    <span className="text-[var(--accent)]">{icons.messageCircleQuestion}</span>
                    <h2 className="text-2xl font-bold text-[var(--text)]">Perguntas frequentes</h2>
                  </div>
                  <div className="space-y-3">
                    {FAQ_ITEMS.map((faq, i) => (
                      <details key={i} className="group rounded-[var(--radius)] border border-[var(--border)] overflow-hidden">
                        <summary className="flex items-center justify-between p-4 cursor-pointer hover:bg-[var(--bg-muted)] transition-colors">
                          <span className="font-semibold text-[var(--text)] text-[15px] pr-4">{faq.q}</span>
                          <span className="flex-shrink-0 transition-transform group-open:rotate-180">
                            {icons.chevronDownSm}
                          </span>
                        </summary>
                        <div className="px-4 pb-4 text-sm text-[var(--text-muted)] leading-relaxed">
                          {faq.a}
                        </div>
                      </details>
                    ))}
                  </div>
                </div>

                {/* Author section */}
                <div className="mt-12 p-6 rounded-[var(--radius-lg)] bg-[var(--bg-muted)] border border-[var(--border-light)] flex flex-col sm:flex-row items-start gap-5">
                  <div className="w-14 h-14 rounded-full bg-[var(--accent)] flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
                    {{ autor_nome[:2] | upper }}
                  </div>
                  <div>
                    <h3 className="font-bold text-[var(--text)] mb-1">{{ autor_nome | js_escape }}</h3>
                    <p className="text-xs text-[var(--accent)] font-semibold mb-2">
                      {{ autor_credencial | js_escape }}
                    </p>
                    <p className="text-sm text-[var(--text-muted)] leading-relaxed">
                      Este curso faz parte do material educacional da Brasil GEO, empresa brasileira
                      especializada em Generative Engine Optimization. Para duvidas, entre em contato
                      pelo WhatsApp ou LinkedIn.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </main>

      <Footer />

      {/* JSON-LD */}
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={% raw %}{{
          __html: JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
              {
                "@type": "Course",
                name: "{{ titulo | js_escape }}",
                description: "{{ descricao | js_escape }}",
                provider: {
                  "@type": "Organization",
                  name: "Brasil GEO",
                  url: "https://{{ dominio }}",
                },
                instructor: {
                  "@type": "Person",
                  name: "{{ autor_nome | js_escape }}",
                  url: "https://alexandrecaramaschi.com",
                  jobTitle: "{{ autor_credencial | js_escape }}",
                },
                educationalLevel: "{{ nivel_display | js_escape }}",
                inLanguage: "pt-BR",
                numberOfCredits: {{ steps | length }},
                timeRequired: "PT{{ duracao_total_minutos }}M",
                hasCourseInstance: {
                  "@type": "CourseInstance",
                  courseMode: "online",
                  courseWorkload: "PT{{ duracao_total_minutos }}M",
                },
              },
              {
                "@type": "FAQPage",
                mainEntity: [
{% for item in faq %}
                  {
                    "@type": "Question",
                    name: "{{ item.pergunta | js_escape }}",
                    acceptedAnswer: {
                      "@type": "Answer",
                      text: "{{ item.resposta | js_escape }}",
                    },
                  },
{% endfor %}
                ],
              },
              {
                "@type": "BreadcrumbList",
                itemListElement: [
                  { "@type": "ListItem", position: 1, name: "Inicio", item: "https://{{ dominio }}" },
                  { "@type": "ListItem", position: 2, name: "Educacao", item: "https://{{ dominio }}/educacao" },
                  { "@type": "ListItem", position: 3, name: "{{ breadcrumb_label | js_escape }}" },
                ],
              },
            ],
          }),
        }}{% endraw %}
      />
    </>
  );
}
