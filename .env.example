# curso-factory — Chaves de API (5 LLMs)
# Copie para .env e preencha com suas chaves reais
# Fonte de verdade: geo-orchestrator/.env

# Perplexity — Pesquisa
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxx

# OpenAI — Redação (GPT-4o)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Google — Análise (Gemini)
GOOGLE_API_KEY=AIzaxxxxxxxxxxxx

# Groq — Classificação (Llama 3.3)
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Anthropic — Revisão (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# FinOps — Limites diários em USD
FINOPS_LIMIT_PERPLEXITY=5.00
FINOPS_LIMIT_OPENAI=8.00
FINOPS_LIMIT_GOOGLE=2.00
FINOPS_LIMIT_GROQ=1.00
FINOPS_LIMIT_ANTHROPIC=8.00

# Cache
CACHE_DIR=.cache
CACHE_TTL_HOURS=24
